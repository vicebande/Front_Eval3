{
  "family": "frontend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::687545780788:role/LabRole",
  "taskRoleArn": "arn:aws:iam::687545780788:role/LabRole",
  "containerDefinitions": [
    {
      "name": "frontend-container",
      "image": "687545780788.dkr.ecr.us-east-1.amazonaws.com/product-frontend:latest",
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/frontend-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
